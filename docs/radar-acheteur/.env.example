# ---- Mailbox (IMAP) ----
IMAP_HOST=imap.gmail.com
IMAP_SSL=true
IMAP_USER=matrix-alerts@yourdomain.com
IMAP_PASS=your_gmail_app_password        # Gmail: Account > Security > App passwords
IMAP_FOLDER=INBOX
# Comma-separated senders to process (Matrix/Centris notification addresses):
ALERT_SENDERS=noreply@matrixmailer.com,notification@centris.ca

# ---- Anthropic ----
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ---- Follow Up Boss ----
FUB_API_KEY=your_fub_api_key             # FUB > Admin > API
FUB_X_SYSTEM=RadarAcheteur
FUB_X_SYSTEM_KEY=

# ---- Broker / digest ----
BROKER_NAME=Danny
BROKER_EMAIL=danny@brokerage.com
BROKER_LANG=fr
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# SMTP_USER / SMTP_PASS default to IMAP creds if blank

# ---- Scoring (tune during pilot) ----
HALF_LIFE_DAYS=7
HOT_THRESHOLD=12
WARM_THRESHOLD=5
LOOKBACK_DAYS=30

# ---- Storage ----
DB_PATH=radar.db
