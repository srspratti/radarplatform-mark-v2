# ============ Radar Hub (plateforme) ============
RADAR_API_KEY=              # vide = ouvert (dev). Prod: exigé via X-Radar-Key
RADAR_TENANT_ID=danny
RADAR_DB_URL=sqlite:///./radar_hub.db
ANTHROPIC_API_KEY=          # concierge Vitrine + prévisions + fallbacks Haiku
RADAR_HAIKU_MODEL=claude-haiku-4-5-20251001
FUB_API_KEY=                # Follow Up Boss — import leads + writeback notes
VITRINE_WEBHOOK_SECRET=     # HMAC des webhooks portail (vide = dev)
RADAR_HALF_LIFE_DAYS=7
RADAR_DORMANT_DAYS=14
RADAR_EDITION=marketable

# --- Adresse d'alerte par client (conçue à la volée, à la conversion) ---
INTAKE_EMAIL_MODE=plus      # plus: user+tag@gmail.com | alias: tag@domaine
INTAKE_EMAIL_USER=alertes.radar@gmail.com
INTAKE_EMAIL_DOMAIN=inbox.radar.example

# ============ Matrix (hub, ingestion courriel ToS-safe) ============
MATRIX_IMAP_HOST=
MATRIX_IMAP_USER=
MATRIX_IMAP_PASS=
MATRIX_IMAP_FOLDER=INBOX

# ============ Radar Acheteur (module monté à /acheteur) ============
DB_PATH=./radar_acheteur.db # partagé: package acheteur + pont hub
IMAP_HOST=imap.gmail.com    # boîte des alertes Matrix (voir docs/radar-acheteur)
IMAP_USER=
IMAP_PASS=

# ============ Phase 2 — système de génération de leads (slot) ============
# Le futur système se branche via POST /api/leads (source=own_generated)
# ou un connecteur dédié — voir README « Slot Phase 2 ».
